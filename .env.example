# ──────────────────────────────────────────────────────────────────
#  .env.example — ContaAzul → PostgreSQL Integration
#  Copie este arquivo para .env e preencha com suas credenciais reais
#  NÃO commite o arquivo .env no git (adicione .env ao .gitignore)
# ──────────────────────────────────────────────────────────────────

# ── ContaAzul OAuth2 ───────────────────────────────────────────────
# Encontre em: ContaAzul > Configurações > Integrações > API
CA_CLIENT_ID=seu_client_id_aqui
CA_CLIENT_SECRET=seu_client_secret_aqui

# O refresh_token é de longa duração (não expira em 1h como o access_token).
# Gere-o no fluxo OAuth 2.0 do ContaAzul e guarde aqui.
CA_REFRESH_TOKEN=seu_refresh_token_aqui

# ── PostgreSQL (Neon) ──────────────────────────────────────────────
# Formato: postgresql://usuario:senha@host:porta/banco?sslmode=require
# O parâmetro sslmode=require é obrigatório para o Neon.
DATABASE_URL=postgresql://usuario:senha@ep-xxx.us-east-2.aws.neon.tech:5432/neondb?sslmode=require

# ── Uso em produção (GitHub Actions) ──────────────────────────────
# Adicione as 4 variáveis acima como Secrets no repositório:
# Settings > Secrets and variables > Actions > New repository secret
